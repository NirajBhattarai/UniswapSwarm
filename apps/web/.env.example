# ─── Web app environment variables (example) ───────────────────────────────
# Copy this file to .env and fill in your secrets/keys.
#
# FRONTEND (exposed to browser):
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4000
NEXT_PUBLIC_COPILOTKIT_RUNTIME_URL=/api/copilotkit
NEXT_PUBLIC_REOWN_PROJECT_ID=

# BACKEND (server-only):
ORCHESTRATOR_URL=http://localhost:4000
COPILOTKIT_MODEL=gemini-2.5-flash
GOOGLE_GENERATIVE_AI_API_KEY=
UNISWAP_API_KEY=
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ALCHEMY_API_KEY=your_key_here

# ─── Managed wallet encryption (server-only) ─────────────────────────────────
# Separate DynamoDB table that stores server-generated managed wallets,
# one per connected user address. Keys are encrypted at rest with AES-256-GCM.
DYNAMODB_WALLETS_TABLE=uniswap-swarm-wallets
DYNAMODB_REGION=us-east-1

# 32-byte AES-256-GCM key as 64 lowercase hex chars.
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER expose this in any NEXT_PUBLIC_ variable or client-side code.
WALLET_ENCRYPTION_KEY=

# AWS credentials for DynamoDB (wallets table + optional history table).
# On Railway/EC2/ECS you can use an IAM role instead — leave these blank.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ─── ENS (read-only, for /api/ens/agents proxy if needed) ────────────────────
# The web app itself does not write ENS records — the orchestrator does.
# Only set ENS_RPC_URL here if you call the ENS registry directly from web.
# ENS_RPC_URL=

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info   # debug | info | warn | error (default: info)
