# ─── Uniswap Swarm — Web App Environment Variables ─────────────────────────
# Copy this file to .env.local and fill in your values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-only (Next.js API routes).


# ── Frontend (browser-visible) ───────────────────────────────────────────────

# URL of the running orchestrator service (used by SSE and history calls).
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4000

# CopilotKit runtime endpoint — leave as /api/copilotkit unless self-hosting.
NEXT_PUBLIC_COPILOTKIT_RUNTIME_URL=/api/copilotkit

# Reown (WalletConnect) project ID — create one at https://cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=


# ── LLM / Orchestrator ───────────────────────────────────────────────────────

# Internal URL the Next.js API routes use to reach the orchestrator.
# Must match NEXT_PUBLIC_ORCHESTRATOR_URL unless behind a reverse proxy.
ORCHESTRATOR_URL=http://localhost:4000

# Gemini model used by the CopilotKit orchestrator runtime.
# Options: gemini-2.5-flash | gemini-2.5-pro | gemini-2.0-flash
COPILOTKIT_MODEL=gemini-2.5-flash

# Google Generative AI key — required for the CopilotKit Gemini adapter.
# Get yours at https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=


# ── Swap execution ───────────────────────────────────────────────────────────

# Uniswap Trading API key — used by /api/swap/prepare and /api/swap/execute.
# Register at https://developers.uniswap.org/dashboard
UNISWAP_API_KEY=

# Ethereum mainnet JSON-RPC URL — used by /api/swap/prepare for allowance checks.
# Alchemy, Infura, or any standard eth_call-compatible endpoint works.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Alchemy API key — used by /api/wallet/portfolio for live token balance lookup
# (alchemy_getTokenBalances). Without this, balances fall back to eth_getBalance only.
# Get yours at https://dashboard.alchemy.com
ALCHEMY_API_KEY=


# ── Managed wallets ──────────────────────────────────────────────────────────
# Each connected EOA gets a unique server-generated wallet for 0G chain operations.
# Private keys are stored encrypted at rest in DynamoDB.

# 0G chain RPC — used by /api/wallet/managed to check the managed wallet's A0GI balance.
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai

# DynamoDB table that stores encrypted managed wallet records (one row per EOA).
DYNAMODB_WALLETS_TABLE=uniswap-swarm-wallets

# AWS region for the DynamoDB wallets table.
DYNAMODB_REGION=us-east-1

# AES-256-GCM encryption key for managed wallet private keys — 64 hex chars (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠ NEVER put this in a NEXT_PUBLIC_ variable or commit it to version control.
WALLET_ENCRYPTION_KEY=

# AWS credentials for DynamoDB access.
# On Railway / EC2 / ECS you can use an IAM role — leave these blank in that case.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only needed for temporary STS credentials


# ── Logging ──────────────────────────────────────────────────────────────────

# Log verbosity: debug | info | warn | error  (default: info)
# LOG_LEVEL=info
