# Backend/orchestrator env only (apps/orchestrator + agents + shared packages).
# Web-specific vars live in apps/web/.env(.local).

# ----------------------------
# Required
# ----------------------------
ZG_PRIVATE_KEY=your_64_char_hex_private_key_here

# ----------------------------
# Core chain/network
# ----------------------------
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ETH_RPC_URL=https://eth.llamarpc.com
ZG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZG_COMPUTE_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZG_FLOW_CONTRACT=0xbD2C3F0E65eDF5582141C35969d66e205E00C9c8

# 0G Compute inference (optional). Research / Planner / Strategy agents use ZGCompute.
# Leave unset to use the first chatbot service. Set to pin a provider or fine-tuned model id.
# ZG_INFERENCE_PROVIDER=0xA02b95Aa6886b1116C4f334eDe00381511E31A09
# ZG_INFERENCE_MODEL=Qwen2.5-0.5B-Instruct
# ZG_FINE_TUNE_TASK_ID=

# ----------------------------
# Optional data/API providers
# ----------------------------
UNISWAP_API_KEY=
COINGECKO_API_KEY=
ALCHEMY_API_KEY=

# ----------------------------
# Optional runtime controls
# ----------------------------
MAX_SLIPPAGE_PCT=1.5
MAX_POSITION_USDC=50
MIN_LIQUIDITY_USD=100000
MAX_GAS_GWEI=30
RISK_SCORE_THRESHOLD=70
DRY_RUN=true
SIMULATION_ONLY=false
CYCLE_INTERVAL_MS=300000
AUTO_CYCLE_ENABLED=false
PORT=4000
A2A_PUBLIC_BASE_URL=http://localhost:4000

# ----------------------------
# Optional DynamoDB persistence
# ----------------------------
DYNAMODB_REGION=
DYNAMODB_HISTORY_TABLE=
DYNAMODB_HISTORY_GSI_USER=GSI1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ----------------------------
# Managed per-user wallets
# ----------------------------
# Separate DynamoDB table that stores server-generated managed wallets,
# one per connected user address. Keys are encrypted at rest with AES-256-GCM.
DYNAMODB_WALLETS_TABLE=uniswap-swarm-wallets

# 32-byte AES-256-GCM key as 64 lowercase hex chars.
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER expose this in any NEXT_PUBLIC_ variable or client-side code.
WALLET_ENCRYPTION_KEY=

# ----------------------------
# ENS agent registry (Sepolia)
# ----------------------------
# Each agent has a subdomain under uniswapswarm.eth with a text[url] record.
# ENS is the single source of truth for A2A endpoint discovery.
#
# Required for: setup-ens, approve-ens-delegate, call-agent, and orchestrator
# self-registration (publishAgentUrlsToEns at startup).
ENS_RPC_URL=

# Owner key — controls uniswapswarm.eth. Required for setup-ens (first run)
# and approve-ens-delegate (one-time). After delegate is approved, use
# ENS_RECORDS_PRIVATE_KEY instead (safer for CI / Railway).
ENS_OWNER_PRIVATE_KEY=

# Delegate (hot-wallet) key — set after running approve-ens-delegate.
# The orchestrator uses this to self-register text[url] on startup.
# Preferred over ENS_OWNER_PRIVATE_KEY for automated deployments.
# ENS_RECORDS_PRIVATE_KEY=

# Address of the delegate wallet to approve (used by approve-ens-delegate only).
# ENS_DELEGATE_ADDRESS=

# Base URL written as text[url] on each agent subname (setup-ens.ts).
# Defaults to http://localhost:4000. Set to your Railway URL when deployed.
# ENS_AGENT_BASE_URL=https://your-deployment.railway.app

# Fallback Ethereum address set as addr() on each agent subname.
# Defaults to the signer wallet address.
# AGENT_ADDRESS=

# Per-agent addr() overrides (all default to AGENT_ADDRESS / signer wallet).
# ENS_ADDR_RESEARCHER=
# ENS_ADDR_PLANNER=
# ENS_ADDR_RISK=
# ENS_ADDR_STRATEGY=
# ENS_ADDR_CRITIC=
# ENS_ADDR_EXECUTOR=

# ----------------------------
# Logging
# ----------------------------
# LOG_LEVEL=info   # debug | info | warn | error (default: info)
