# ─── 0G Network ───────────────────────────────────────────────────────────────
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZG_PRIVATE_KEY=your_64_char_hex_private_key_here
ZG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZG_FLOW_CONTRACT=0xbD2C3F0E65eDF5582141C35969d66e205E00C9c8

# ─── Uniswap Trading API (https://developers.uniswap.org/dashboard) ──────────
# Get your key at https://developers.uniswap.org/dashboard
# Used for real-time token price quotes via the Uniswap Trading API.
# If empty, the system falls back to on-chain QuoterV2 + slot0 pricing.
UNISWAP_API_KEY=

# ─── CoinGecko API (https://www.coingecko.com/en/api) ────────────────────────
# Free demo key: sign up at https://www.coingecko.com/en/api/pricing (free tier)
# Used for 24h volume, price change %, and market cap data in the Research Agent.
# If empty, volume/market data will be skipped (prices still work via Uniswap API).
COINGECKO_API_KEY=

# ─── Ethereum (for Uniswap) ───────────────────────────────────────────────────
# Use a real Alchemy / Infura / Ankr URL for mainnet
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ─── Risk constraints ─────────────────────────────────────────────────────────
MAX_SLIPPAGE_PCT=1.5
MAX_POSITION_USDC=50
MIN_LIQUIDITY_USD=100000
MAX_GAS_GWEI=30
RISK_SCORE_THRESHOLD=70

# ─── Execution mode ───────────────────────────────────────────────────────────
# DRY_RUN=true  → simulate only, no real transactions
# DRY_RUN=false → LIVE TRADING ⚠️  Only set false when you are ready
DRY_RUN=true

# ─── Swarm behaviour ─────────────────────────────────────────────────────────
# CYCLE_INTERVAL_MS=0  → manual-only (trigger via POST /cycle)
# CYCLE_INTERVAL_MS=300000 → auto-cycle every 5 minutes
CYCLE_INTERVAL_MS=0
PORT=4000

# ─── A2A / CopilotKit integration ─────────────────────────────────────────────
# Public base URL for A2A agent-card links exposed by orchestrator.
# If unset, defaults to http://localhost:${PORT}
A2A_PUBLIC_BASE_URL=http://localhost:4000

# Frontend URL used by the web app for orchestrator API/A2A requests.
# If unset in the web app, code defaults to http://localhost:4000.
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4000

# CopilotKit runtime endpoint used by <CopilotKit /> provider in apps/web.
# If unset, code defaults to /api/copilotkit.
NEXT_PUBLIC_COPILOTKIT_RUNTIME_URL=/api/copilotkit

# Model + credentials used by apps/web CopilotKit runtime route (Gemini).
# Preferred key name (matches Gemini SDK): GOOGLE_GENERATIVE_AI_API_KEY
# Fallbacks supported by our code: GOOGLE_API_KEY or GEMINI_API_KEY
COPILOTKIT_MODEL=gemini-2.5-flash
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# ─── Standalone A2A agent servers (one per Uniswap Swarm agent) ──────────────
# Each Uniswap Swarm agent (researcher, planner, risk, strategy, critic,
# executor) runs as its own A2A server on a dedicated port. The CopilotKit
# A2AMiddlewareAgent in apps/web registers these URLs and the orchestrator LLM
# routes calls via the auto-injected `send_message_to_a2a_agent` tool.
#
# Override either the port (server-side) or the full URL (web-side) per agent.
RESEARCHER_PORT=4101
PLANNER_PORT=4102
RISK_PORT=4103
STRATEGY_PORT=4104
CRITIC_PORT=4105
EXECUTOR_PORT=4106

# Web-side overrides (only set if you run the agents on a different host)
# RESEARCHER_AGENT_URL=http://localhost:4101
# PLANNER_AGENT_URL=http://localhost:4102
# RISK_AGENT_URL=http://localhost:4103
# STRATEGY_AGENT_URL=http://localhost:4104
# CRITIC_AGENT_URL=http://localhost:4105
# EXECUTOR_AGENT_URL=http://localhost:4106

# Bind address + public hostname used in the agent cards. Leave defaults for
# local dev; set A2A_PUBLIC_HOST=http://your-host when deploying.
# A2A_HOST=0.0.0.0
# A2A_PUBLIC_HOST=http://localhost
