# Backend/orchestrator env only (apps/orchestrator + agents + shared packages).
# Web-specific vars live in apps/web/.env(.local).

# ----------------------------
# Required
# ----------------------------
ZG_PRIVATE_KEY=your_64_char_hex_private_key_here

# ----------------------------
# Core chain/network
# ----------------------------
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ETH_RPC_URL=https://eth.llamarpc.com
ZG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZG_FLOW_CONTRACT=0xbD2C3F0E65eDF5582141C35969d66e205E00C9c8

# ----------------------------
# Optional data/API providers
# ----------------------------
UNISWAP_API_KEY=
COINGECKO_API_KEY=
ALCHEMY_API_KEY=

# ----------------------------
# Optional runtime controls
# ----------------------------
MAX_SLIPPAGE_PCT=1.5
MAX_POSITION_USDC=50
MIN_LIQUIDITY_USD=100000
MAX_GAS_GWEI=30
RISK_SCORE_THRESHOLD=70
DRY_RUN=true
SIMULATION_ONLY=false
CYCLE_INTERVAL_MS=300000
AUTO_CYCLE_ENABLED=false
PORT=4000
A2A_PUBLIC_BASE_URL=http://localhost:4000

# ----------------------------
# Optional DynamoDB persistence
# ----------------------------
DYNAMODB_REGION=
DYNAMODB_HISTORY_TABLE=
DYNAMODB_HISTORY_GSI_USER=GSI1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
