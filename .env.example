# ─── Uniswap Swarm — Backend / Orchestrator Environment Variables ────────────
# Used by: apps/orchestrator, agents/*, and packages/shared.
# Web-specific variables live in apps/web/.env.local.
# Copy this file to .env and fill in your values.


# ── 0G Network ───────────────────────────────────────────────────────────────

# Private key for the scripts/fund-ledger.ts maintenance script only.
# NOT used by the orchestrator or any agent — all pipeline runs use
# per-user managed wallets (one per connected EOA, stored in DynamoDB).
# Pass inline when running the script:
#   FUND_LEDGER_PRIVATE_KEY=<hex> pnpm tsx scripts/fund-ledger.ts
# FUND_LEDGER_PRIVATE_KEY=

# 0G chain JSON-RPC endpoint (EVM-compatible).
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai

# 0G Storage node RPC — used for uploading agent blackboard entries.
ZG_STORAGE_RPC=https://evmrpc-testnet.0g.ai

# 0G Storage indexer RPC — used for downloading entries and content-addressing.
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# 0G Compute indexer RPC — used for ledger top-up and inference billing.
ZG_COMPUTE_RPC=https://indexer-storage-testnet-turbo.0g.ai

# 0G Flow contract address on the target chain (do not change unless using a fork).
ZG_FLOW_CONTRACT=0xbD2C3F0E65eDF5582141C35969d66e205E00C9c8

# Override the OpenAI-compatible model name sent to 0G Compute inference.
# Leave unset to use whatever model the network service advertises.
# ZG_INFERENCE_MODEL=Qwen2.5-0.5B-Instruct


# ── Ethereum ─────────────────────────────────────────────────────────────────

# Ethereum mainnet JSON-RPC — used by strategy/executor agents for on-chain calls.
# Any eth_call-compatible endpoint works (Alchemy, Infura, public RPC).
ETH_RPC_URL=https://eth.llamarpc.com


# ── External API keys ────────────────────────────────────────────────────────

# Uniswap Trading API key — used by executor agent for swap calldata.
# Register at https://developers.uniswap.org/dashboard
UNISWAP_API_KEY=

# CoinGecko API key — used by researcher agent for live market data.
# Free demo key works; pro key removes rate limits. https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Alchemy API key — used by strategy agent (alchemy_getTokenBalances) to fetch
# full ERC-20 holdings for the connected wallet. Falls back to known-token list.
# Get yours at https://dashboard.alchemy.com
ALCHEMY_API_KEY=


# ── Trade safety constraints ─────────────────────────────────────────────────

# Maximum allowed slippage for any swap (%).
MAX_SLIPPAGE_PCT=1.5

# Maximum single-trade size in USD.
MAX_POSITION_USDC=50

# Minimum pool liquidity required before a token is considered (USD).
MIN_LIQUIDITY_USD=100000

# Maximum gas price the executor will accept (Gwei). Swaps abort above this.
MAX_GAS_GWEI=30

# Minimum composite risk score (0–100) a candidate must pass before strategy picks it.
RISK_SCORE_THRESHOLD=70


# ── Execution mode ───────────────────────────────────────────────────────────

# When true, the executor simulates swaps without broadcasting a transaction.
# Set to false only when you are ready for real on-chain execution.
DRY_RUN=true

# When true, the executor agent skips the Uniswap Trading API entirely and
# returns a mock result. Useful for unit tests and offline demos.
SIMULATION_ONLY=false


# ── Orchestrator behaviour ───────────────────────────────────────────────────

# Milliseconds between autonomous pipeline cycles (default 5 min).
CYCLE_INTERVAL_MS=300000

# Max tokens for agent LLM inference calls (applies to all agents).
# Alias: RESEARCHER_MAX_INFER_TOKENS is also accepted for backwards compat.
AGENT_MAX_INFER_TOKENS=6144

# Set to true to enable autonomous background cycling without a user prompt.
AUTO_CYCLE_ENABLED=false

# HTTP port the orchestrator listens on.
PORT=4000

# Public base URL written into A2A agent cards and ENS text records.
# Set to your Railway/Fly/Render URL when deployed.
A2A_PUBLIC_BASE_URL=http://localhost:4000


# ── DynamoDB — pipeline history ──────────────────────────────────────────────
# Optional. When set, each completed pipeline cycle is persisted to DynamoDB
# so users can browse past runs in the history panel.

# AWS region for the history table.
DYNAMODB_REGION=

# DynamoDB table name for cycle history records.
DYNAMODB_HISTORY_TABLE=

# Name of the GSI used to query cycles by userId (created by create-dynamo-tables).
DYNAMODB_HISTORY_GSI_USER=GSI1


# ── DynamoDB — managed wallets ───────────────────────────────────────────────
# Each connected EOA gets a unique server-generated wallet for 0G chain ops.
# Private keys are encrypted at rest with AES-256-GCM before storage.

# DynamoDB table that stores encrypted managed wallet records.
DYNAMODB_WALLETS_TABLE=uniswap-swarm-wallets

# AES-256-GCM encryption key — 64 hex chars (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠ Must match the value set in apps/web/.env.local — both services share this key.
# ⚠ NEVER commit this value or expose it in any public variable.
WALLET_ENCRYPTION_KEY=


# ── AWS credentials (shared by both DynamoDB tables) ────────────────────────
# On Railway / EC2 / ECS use an IAM role — leave these blank in that case.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only needed for temporary STS credentials


# ── ENS agent registry (Sepolia) ────────────────────────────────────────────
# Each agent is discoverable via a subdomain of uniswapswarm.eth.
# ENS text[url] records are the single source of truth for A2A endpoint URLs.

# Sepolia RPC used to read/write ENS records.
# Required for: setup-ens, approve-ens-delegate, call-agent scripts,
# and orchestrator startup self-registration.
ENS_RPC_URL=

# Owner private key — controls uniswapswarm.eth.
# Required only for setup-ens (first-time) and approve-ens-delegate.
# After the delegate is approved, use ENS_RECORDS_PRIVATE_KEY instead.
ENS_OWNER_PRIVATE_KEY=

# Delegate (hot-wallet) private key — used by the orchestrator to publish
# text[url] records on startup. Safer than the owner key for CI/Railway.
# ENS_RECORDS_PRIVATE_KEY=

# Delegate wallet address to approve (used by approve-ens-delegate script only).
# ENS_DELEGATE_ADDRESS=

# Public base URL written as text[url] on each agent subname.
# Defaults to A2A_PUBLIC_BASE_URL. Override if the ENS URL differs.
# ENS_AGENT_BASE_URL=https://your-deployment.railway.app

# Ethereum address set as addr() on all agent subnames (defaults to signer address).
# AGENT_ADDRESS=

# Per-agent addr() overrides — all default to AGENT_ADDRESS if unset.
# ENS_ADDR_RESEARCHER=
# ENS_ADDR_PLANNER=
# ENS_ADDR_RISK=
# ENS_ADDR_STRATEGY=
# ENS_ADDR_CRITIC=
# ENS_ADDR_EXECUTOR=


# ── Logging ──────────────────────────────────────────────────────────────────

# Log verbosity: debug | info | warn | error  (default: info)
# LOG_LEVEL=info
